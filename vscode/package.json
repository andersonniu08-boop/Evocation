{
  "name": "memorydog",
  "displayName": "MemoryDog",
  "description": "A memory-augmented coding agent — persistent memory, hybrid retrieval, and instincts",
  "version": "0.1.0",
  "publisher": "memorydog-dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/andersonniu08-boop/MemoryDog.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:memorydog.focusChat",
    "onCommand:memorydog.showQuickActions",
    "onCommand:memorydog.configure",
    "onView:memorydog.chatView",
    "onView:memorydog.memoryPanel",
    "onView:memorydog.instinctPanel",
    "onView:memorydog.dogView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "memorydog.focusChat",
        "title": "MemoryDog: Focus Chat"
      },
      {
        "command": "memorydog.showQuickActions",
        "title": "MemoryDog: Quick Actions"
      },
      {
        "command": "memorydog.configure",
        "title": "MemoryDog: Configure API Key"
      },
      {
        "command": "memorydog.start",
        "title": "MemoryDog: Start Agent (legacy)"
      },
      {
        "command": "memorydog.startChat",
        "title": "MemoryDog: Start Chat (legacy)"
      },
      {
        "command": "memorydog.showMemoryPanel",
        "title": "MemoryDog: Show Memory Browser"
      },
      {
        "command": "memorydog.showInstinctPanel",
        "title": "MemoryDog: Show Instincts"
      },
      {
        "command": "memorydog.showDogView",
        "title": "MemoryDog: Show Mascot"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "memorydog",
          "title": "MemoryDog",
          "icon": "assets/dog/idle.png"
        }
      ]
    },
    "views": {
      "memorydog": [
        {
          "type": "webview",
          "id": "memorydog.chatView",
          "name": "Chat"
        },
        {
          "type": "webview",
          "id": "memorydog.memoryPanel",
          "name": "Memories"
        },
        {
          "type": "webview",
          "id": "memorydog.instinctPanel",
          "name": "Instincts"
        },
        {
          "type": "webview",
          "id": "memorydog.dogView",
          "name": "Mascot"
        }
      ]
    },
    "configuration": {
      "title": "MemoryDog",
      "properties": {
        "memorydog.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for your LLM provider (e.g. DeepSeek, OpenAI, Anthropic)"
        },
        "memorydog.model": {
          "type": "string",
          "default": "deepseek/deepseek-chat",
          "description": "LiteLLM model string (e.g. deepseek/deepseek-chat, openai/gpt-4o, anthropic/claude-sonnet-4-20250514)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
